# Plan file (set after running /paicer-plan)
# PLAN=plans/my-plan.yaml

# Workout integration (uncomment if using Garmin)
# WORKOUT_INTEGRATION=garmin
# GARMIN_EMAIL=your-email@example.com
# GARMIN_PASSWORD=your-password-here

# Paper format for HTML output (letter or a4)
FORMAT=letter

# Unit system for plan generation (metric or imperial)
UNITS=metric
