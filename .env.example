# Workout integration (garmin is the only supported integration currently)
WORKOUT_INTEGRATION=garmin

# Garmin Connect credentials (if using garmin provider)
GARMIN_EMAIL=your-email@example.com
GARMIN_PASSWORD=your-password-here

# Plan file (required)
PLAN=examples/hm-tri-combo.yaml

# Paper format for HTML output (letter or a4)
FORMAT=letter
